# XRay — Environment Variables
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL="file:./dev.db"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="XRay Security Analyzer"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# File Upload
MAX_FILE_SIZE_MB=50

# Security
CSRF_SECRET="change-me-to-a-random-string-at-least-32-chars"
API_KEY_SALT="change-me-to-a-random-string"

# Optional: VirusTotal Integration
# VIRUSTOTAL_API_KEY=""

# Optional: Chrome Web Store API
# CHROME_WEBSTORE_API_KEY=""
